# ARTIFACT_URL=

# - defaults to "GoNotoCurrent-Regular.ttf"
# FONT_NAME=

# - defaults to "${FONT_DIR}/${FONT_NAME}"
# FONT_PATH=

# - defaults to "INFO"
# LOGLEVEL=

# --- General ---

# - e.g. "utf-8
#OUTPUT_ENCODING=

# - e.g. "JPEG"
#OUTPUT_IMAGE_FORMAT=

# --- LLM ---

#GOOGLE_API_KEY=

