# Contains values for environment variables of tools that are used by marker

# --- Python ---

# - If this is set to a non-empty string it is equivalent to specifying the -u option, i.e.
# - Force the stdout and stderr streams to be unbuffered. This option has no effect on the stdin stream.
PYTHONUNBUFFERED=1

# --- Hugging Face ---

# - If set, no HTTP calls will be made to the Hugging Face Hub.
# - If you try to download files, only the cached files will be accessed.
# - If no cache file is detected, an error is raised This is useful in case
# - your network is slow and you don’t care about having the latest version of a file.
HF_HUB_OFFLINE=1

# --- Transformers Library ---

# - If set to 1, the library will not download the model weights.
TRANSFORMERS_OFFLINE=1

# --- vLLM ---
MARKLLM_VLLM_PORT=8001

# --- Pytorch ---

# - If 1, falls back to CPU when MPS ops aren’t supported
PYTORCH_ENABLE_MPS_FALLBACK=1

# - Sets the number of threads used for intraop parallelism on CPU
TORCH_NUM_THREADS=1

# - Sets the number of threads used for interop parallelism on CPU
OPENBLAS_NUM_THREADS=1

# - Sets the maximum number of threads to use for OpenMP parallel regions.
OMP_NUM_THREADS=1

# - The OMP_DYNAMIC environment variable enables OpenMP library to dynamically change the number of threads.
OMP_DYNAMIC=FALSE

# - Sets the maximum number of threads to use for the Intel MKL library.
# - Note that `MKL_NUM_THREADS` takes precedence over `OMP_NUM_THREADS`
MKL_NUM_THREADS=1

# - The MKL_DYNAMIC environment variable enables MKL library to dynamically change the number of threads.
MKL_DYNAMIC=FALSE
