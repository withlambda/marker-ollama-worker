# Contains values for MinerU specified environment variables

# --- Paths---

# - base dir
# BASE_DIR=

# - defaults to "${BASE_DIR}/conversion_results"
# OUTPUT_DIR=

# - defaults to "${BASE_DIR}/static/fonts"
# FONT_DIR=

# - defaults to "${BASE_DIR}/debug_data"
# DEBUG_DATA_FOLDER=

# - defaults to "https://models.datalab.to/artifacts"
# ARTIFACT_URL=

# - defaults to "GoNotoCurrent-Regular.ttf"
# FONT_NAME=

# - defaults to "${FONT_DIR}/${FONT_NAME}"
# FONT_PATH=

# - defaults to "INFO"
# LOGLEVEL=

# --- General ---

# - e.g. "utf-8
#OUTPUT_ENCODING=

# - e.g. "JPEG"
#OUTPUT_IMAGE_FORMAT=

# --- LLM ---

#GOOGLE_API_KEY=

# --- General models ---

# - one of "cpu", "cuda", or "mps"
TORCH_DEVICE=cpu
