# Contains values for self managed environment variables
VOLUME_ROOT_MOUNT_PATH=/v
HANDLER_FILE_NAME=test-handler.py
USE_POSTPROCESS_LLM=false
MARKER_DEBUG=true
MARKER_DISABLE_MAXTASKSPERCHILD=true
VLLM_MODEL=unsloth/SmolLM2-135M-Instruct-GGUF
VLLM_CPU=true
VRAM_GB_TOTAL=8
VLLM_VRAM_GB_MODEL=6
VLLM_GPU_UTIL=0.90
VLLM_PORT=8000
